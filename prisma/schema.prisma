generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Process {
  processNumber       String              @id @map("process_number")
  sourceSubsidies     Boolean             @default(false) @map("source_subsidies")
  sourceOutcomes      Boolean             @default(false) @map("source_outcomes")
  createdAt           DateTime            @default(now()) @map("created_at")
  subsidies           ProcessSubsidies?
  outcome             ProcessOutcome?
  caseFeatures        ProcessCaseFeatures?
  recommendationRuns  RecommendationRun[]

  @@map("processes")
}

model ProcessSubsidies {
  processNumber            String   @id @map("process_number")
  contractProvided         Boolean  @map("contract_provided")
  statementProvided        Boolean  @map("statement_provided")
  creditProofProvided      Boolean  @map("credit_proof_provided")
  dossierProvided          Boolean  @map("dossier_provided")
  debtEvolutionProvided    Boolean  @map("debt_evolution_provided")
  referencedReportProvided Boolean  @map("referenced_report_provided")
  loadedAt                 DateTime @default(now()) @map("loaded_at")
  process                  Process  @relation(fields: [processNumber], references: [processNumber], onDelete: Cascade)

  @@map("process_subsidies")
}

model ProcessOutcome {
  processNumber             String   @id @map("process_number")
  uf                        String
  subject                   String
  subSubject                String   @map("sub_subject")
  resultMacro               String   @map("result_macro")
  resultMicro               String   @map("result_micro")
  claimAmountCents          Int      @map("claim_amount_cents")
  condemnationAmountCents   Int      @map("condemnation_amount_cents")
  loadedAt                  DateTime @default(now()) @map("loaded_at")
  process                   Process  @relation(fields: [processNumber], references: [processNumber], onDelete: Cascade)

  @@index([uf])
  @@index([resultMacro])
  @@index([resultMicro])
  @@map("process_outcomes")
}

model ProcessCaseFeatures {
  processNumber             String   @id @map("process_number")
  uf                        String
  subject                   String
  subSubject                String   @map("sub_subject")
  resultMacro               String   @map("result_macro")
  resultMicro               String   @map("result_micro")
  claimAmountCents          Int      @map("claim_amount_cents")
  condemnationAmountCents   Int      @map("condemnation_amount_cents")
  contractProvided          Boolean  @map("contract_provided")
  statementProvided         Boolean  @map("statement_provided")
  creditProofProvided       Boolean  @map("credit_proof_provided")
  dossierProvided           Boolean  @map("dossier_provided")
  debtEvolutionProvided     Boolean  @map("debt_evolution_provided")
  referencedReportProvided  Boolean  @map("referenced_report_provided")
  subsidyCount              Int      @map("subsidy_count")
  hasFullDocumentation      Boolean  @map("has_full_documentation")
  claimAmountBrl            Float    @map("claim_amount_brl")
  condemnationAmountBrl     Float    @map("condemnation_amount_brl")
  condemnationRatio         Float    @map("condemnation_ratio")
  process                   Process  @relation(fields: [processNumber], references: [processNumber], onDelete: Cascade)

  @@index([uf, subSubject, resultMacro])
  @@map("process_case_features")
}

model PolicyVersion {
  policyVersion         String              @id @map("policy_version")
  policyText            String              @map("policy_text")
  policyType            String              @default("agreement_policy") @map("policy_type")
  trainSplitRatio       Float               @default(0.7) @map("train_split_ratio")
  validationSplitRatio  Float               @default(0.3) @map("validation_split_ratio")
  status                String              @default("draft")
  createdAt             DateTime            @default(now()) @map("created_at")
  recommendationRuns    RecommendationRun[]

  @@map("policy_versions")
}

model RecommendationRun {
  runId             String         @id @map("run_id")
  processNumber     String?        @map("process_number")
  policyVersion     String?        @map("policy_version")
  recommendedAction String         @map("recommended_action")
  confidenceScore   Float?         @map("confidence_score")
  offerMinCents     Int?           @map("offer_min_cents")
  offerMaxCents     Int?           @map("offer_max_cents")
  usedRules         String?        @map("used_rules")
  explanation       String?
  createdAt         DateTime       @default(now()) @map("created_at")
  process           Process?       @relation(fields: [processNumber], references: [processNumber], onDelete: SetNull)
  policy            PolicyVersion? @relation(fields: [policyVersion], references: [policyVersion], onDelete: SetNull)
  feedbackEvents    FeedbackEvent[]
  overrideEvents    OverrideEvent[]

  @@map("recommendation_runs")
}

model FeedbackEvent {
  feedbackId    String            @id @map("feedback_id")
  runId         String            @map("run_id")
  feedbackType  String            @map("feedback_type")
  feedbackText  String?           @map("feedback_text")
  createdAt     DateTime          @default(now()) @map("created_at")
  run           RecommendationRun @relation(fields: [runId], references: [runId], onDelete: Cascade)

  @@map("feedback_events")
}

model OverrideEvent {
  overrideId       String            @id @map("override_id")
  runId            String            @map("run_id")
  chosenAction     String            @map("chosen_action")
  chosenOfferCents Int?              @map("chosen_offer_cents")
  overrideReason   String?           @map("override_reason")
  createdAt        DateTime          @default(now()) @map("created_at")
  run              RecommendationRun @relation(fields: [runId], references: [runId], onDelete: Cascade)

  @@map("override_events")
}
