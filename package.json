{
  "name": "grupo_4_carona",
  "private": true,
  "type": "module",
  "workspaces": [
    "backend/packages/*"
  ],
  "scripts": {
    "db:generate": "prisma generate",
    "db:push": "node backend/scripts/push-schema.js",
    "db:seed": "node scripts/database/importCsvs.js",
    "start:all": "docker compose up --build",
    "start:all:detached": "docker compose up --build -d",
    "db:studio": "prisma studio",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "backend:api:start": "node --import tsx/esm backend/server.ts",
    "backend:policy:bootstrap": "node --import tsx/esm backend/scripts/bootstrap-policy.ts",
    "backend:policy:ensure": "node --import tsx/esm backend/scripts/ensure-static-policy.ts",
    "backend:demo:workflows": "node --import tsx/esm backend/scripts/run-demo-workflows.ts",
    "backend:typecheck": "tsc -p backend/tsconfig.json --noEmit",
    "backend:test:integration": "NODE_ENV=test node --import tsx/esm --test backend/**/*.integration.test.ts",
    "backend:validate": "npm run backend:typecheck && npm run backend:test:integration",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:integration": "npm run backend:test:integration",
    "validate:all": "npm run backend:validate"
  },
  "dependencies": {
    "@langchain/core": "^0.3.23",
    "@langchain/langgraph": "^0.2.39",
    "@langchain/openai": "^0.4.2",
    "@prisma/client": "^6.19.3",
    "dotenv": "^16.4.5",
    "fastify": "^5.1.0",
    "openai": "^4.77.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "prisma": "^6.19.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
